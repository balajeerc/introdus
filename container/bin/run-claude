#!/usr/bin/env bash
# run-claude — drop into a tmux session running Claude Code in this project's
# working directory. Permission prompts are bypassed by default; pass `--safe`
# to launch with prompts ON.
#
# Remote control is already enabled for every session via
# /home/dev/.claude/settings.json ("remoteControlAtStartup": true), so once you
# pair the session from claude.ai/code or the mobile app you can drive it from
# your phone. This wrapper just adds the two ergonomic bits the harness wants
# by default: cd into the repo and skip the permission prompts so the agent
# runs unattended.
#
# Re-running attaches to the existing 'claude' session instead of spawning a
# second one, so it's safe to fire from multiple shells / reconnects.
set -euo pipefail

# The workload runs as the non-root user `dev`. Ad-hoc `podman exec` sessions
# default to root, so if invoked as root, re-exec as dev (with dev's HOME) so
# Claude runs unprivileged and finds /home/dev/.claude.
if [[ "$(id -u)" -eq 0 ]]; then
    exec setpriv --reuid dev --regid dev --init-groups -- \
        env HOME=/home/dev USER=dev LOGNAME=dev /usr/local/bin/run-claude "$@"
fi

SESSION="claude"

# setup.sh clones the repo to /home/dev/work/<PROJECT_NAME>. PROJECT_NAME is
# passed into the container as an env var and inherited by exec/login shells; if
# it's somehow absent, fall back to the sole project directory under work.
if [[ -n "${PROJECT_NAME:-}" && -d "/home/dev/work/${PROJECT_NAME}" ]]; then
    WORKDIR="/home/dev/work/${PROJECT_NAME}"
else
    WORKDIR="$(find /home/dev/work -mindepth 1 -maxdepth 1 -type d 2>/dev/null | head -1)"
fi

if [[ -z "${WORKDIR:-}" || ! -d "$WORKDIR" ]]; then
    echo "run-claude: could not locate the project working directory under /home/dev/work" >&2
    exit 1
fi

cd "$WORKDIR"

# Claude arguments. The harness default (a bare `run-claude`, as the banner
# suggests) skips the permission prompts so the agent runs unattended. The
# control menu passes an explicit choice: the skip flag to confirm it, or
# `--safe` to launch plain claude with prompts ON. Anything else is passed
# through to claude verbatim.
case "${1:-}" in
    --safe) shift; CLAUDE_ARGS=("$@") ;;
    "")     CLAUDE_ARGS=(--dangerously-skip-permissions) ;;
    *)      CLAUDE_ARGS=("$@") ;;
esac

# Attach to an already-running session rather than starting a duplicate.
if tmux has-session -t "$SESSION" 2>/dev/null; then
    exec tmux attach -t "$SESSION"
fi

exec tmux new-session -s "$SESSION" -c "$WORKDIR" "claude ${CLAUDE_ARGS[*]:-}"
